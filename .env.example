# Copy this file to `.env` and fill in real values.
# NEVER commit .env. It's in .gitignore for a reason.
# Replace "david" in paths below with your actual macOS username if different.

# --- Source-of-truth data directory ---
# The iCloud Drive folder containing contacts/, interactions/, inbox.txt, etc.
DATA_PATH=/Users/david/Library/Mobile Documents/com~apple~CloudDocs/NetworkingCRM

# --- Local SQLite cache (derived from DATA_PATH, disposable) ---
# Lives inside the project, not in iCloud. Safe to delete; rebuilds on next launch.
CACHE_DB_PATH=./data/cache.db

# --- Local log directory ---
LOG_PATH=./data/logs

# --- Git backup repo for the data directory ---
# Separate from the code repo. Auto-committed daily.
BACKUP_PATH=/Users/david/NetworkingCRM-backup

# --- Server ---
PORT=3000
# Always 127.0.0.1 for localhost-only access. Do not change to 0.0.0.0.
BIND_HOST=127.0.0.1

# --- Anthropic API (used from Sprint 07 onward) ---
# Create a key at https://console.anthropic.com/settings/keys
# Set a monthly spend limit in the console before using.
# Stored in Google Drive under MFA-protected account; retrieve and paste here.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MONTHLY_LIMIT_USD=10

# --- Defaults for new records ---
# ISO 3166-1 alpha-2 country code used when a contact has no specified country
# and a phone number is entered without a + prefix.
DEFAULT_COUNTRY=US
